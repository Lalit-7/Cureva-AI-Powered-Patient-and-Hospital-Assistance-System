# ==================== DATABASE ====================
# PostgreSQL connection string from Render.com
# Format: postgresql://username:password@host:port/database
# Uncomment and set your actual database URL for production
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ==================== API KEYS ====================
# Google Gemini API Key - Get from: https://ai.google.dev/
# This is required for AI medical analysis features
GEMINI_API_KEY=your_google_gemini_api_key_here

# Google API Key - Same as above (used interchangeably)
GOOGLE_API_KEY=your_google_api_key_here

# ==================== FLASK CONFIGURATION ====================
# Set to 'development' locally, 'production' on Vercel
FLASK_ENV=development

# Set to 1 for development (shows errors), 0 for production
FLASK_DEBUG=1

# Secret key for session encryption - Generate a random string
# On Windows: python -c "import secrets; print(secrets.token_urlsafe(32))"
# On Mac/Linux: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=generate_a_random_string_for_production

# ==================== NOTES ====================
# ⚠️  IMPORTANT SECURITY GUIDELINES:
# 
# 1. NEVER commit the actual .env file to Git
#    (It's already in .gitignore - good!)
# 
# 2. NEVER share your actual .env file with anyone
#    (contains sensitive credentials)
# 
# 3. For production (Vercel):
#    - Go to Vercel Dashboard → Project Settings → Environment Variables
#    - Add each variable there (Vercel encrypts them)
#    - Do NOT put .env file in Git
# 
# 4. Rotating API Keys (if compromised):
#    - Delete the old key in Google Cloud Console
#    - Generate a new key
#    - Update in .env locally
#    - Update in Vercel settings
#    - All services automatically use the new key
# 
# 5. Keep Local Copy Safe:
#    - Backup .env somewhere secure
#    - Never email it
#    - Never share via Slack/Teams
#    - Only store on your secure computer
